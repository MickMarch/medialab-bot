# medialab-bot DEV environment template.
# Copy to .env.dev and fill in. .env.dev is gitignored - never commit real tokens.
#
# The dev bot MUST use a SEPARATE Discord application/token from prod: two
# processes sharing one token get disconnected by Discord and commands
# double-fire. Create a second Discord application + bot at
# https://discord.com/developers/applications, invite it to a dev/test guild,
# and put its token + that guild id here.

# Separate dev bot identity (NOT the prod token).
DISCORD_TOKEN=
# A dev/test guild so slash commands register separately from prod.
DISCORD_GUILD_ID=

# Resolves inside the dev compose network to the dev gateway container. Same
# service name as prod because it is a different network in the dev project.
ORCHESTRATOR_URL=http://medialab-orchestrator:8000
# Must match the dev orchestrator's API_KEY (its own dev .env).
ORCHESTRATOR_API_KEY=

SELECT_MAX_RESULTS=25
TORRENT_RESULTS_PER_RESOLUTION=5
TORRENT_SEARCH_TIMEOUT_SECONDS=30.0
LOG_LEVEL=DEBUG
