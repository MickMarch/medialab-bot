DISCORD_TOKEN=
DISCORD_GUILD_ID=
# The bot's single downstream dependency: the medialab-orchestrator gateway. In
# Docker, the host is the service name on the shared compose network.
ORCHESTRATOR_URL=http://medialab-orchestrator:8000
ORCHESTRATOR_API_KEY=
SELECT_MAX_RESULTS=25
TORRENT_RESULTS_PER_RESOLUTION=5
TORRENT_SEARCH_TIMEOUT_SECONDS=30.0
LOG_LEVEL=INFO
